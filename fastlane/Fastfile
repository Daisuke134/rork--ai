default_platform(:ios)

platform :ios do
  desc "Build and run on simulator"
  lane :simulator do
    build_app(
      project: "BenYinFanYiAI.xcodeproj",
      scheme: "BenYinFanYiAI",
      destination: "platform=iOS Simulator,name=iPhone 17 Pro",
      configuration: "Debug",
      derived_data_path: "build",
      skip_archive: true,
      skip_codesigning: true,
      buildlog_path: "build/logs"
    )
  end

  desc "Boot simulator and install"
  lane :run_simulator do
    sh("xcrun simctl boot D5822106-E149-46E4-B7B7-50101D59B6D7 2>/dev/null || true")
    sh("open -a Simulator")
    simulator
    app_path = Dir.glob("build/Build/Products/Debug-iphonesimulator/*.app").first
    if app_path
      sh("xcrun simctl install D5822106-E149-46E4-B7B7-50101D59B6D7 '#{app_path}'")
      sh("xcrun simctl launch D5822106-E149-46E4-B7B7-50101D59B6D7 app.honyaku-ai")
    end
  end
end
